{
  "name": "h.s",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "publish:web": "bun rss && expo export -p web",
    "preview:web": "bunx serve dist",
    "rss": "bunx tsx ./src/scripts/rss.ts",
    "rss:node": "node -r esbuild-register ./src/scripts/rss.ts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@react-navigation/native": "^7.0.0",
    "dayjs": "^1.11.9",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.0",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-use": "^17.4.2",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/gtag.js": "^0.0.18",
    "@types/react": "~19.1.10",
    "ajv": "^8.12.0",
    "bun-types": "latest",
    "chalk": "^5.6.2",
    "esbuild": "^0.19.2",
    "esbuild-register": "^3.4.2",
    "globals": "^17.3.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "prettier": "^3.0.3",
    "react-native-svg-transformer": "^1.1.0",
    "rss-parser": "^3.13.0",
    "ts-node": "^10.9.1"
  },
  "engines": {
    "node": ">=22"
  }
}
