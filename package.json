{
  "name": "h.s",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "publish:web": "bun rss && expo export -p web",
    "preview:web": "bunx serve dist",
    "rss": "bunx tsx ./src/scripts/rss.ts",
    "rss:node": "node -r esbuild-register ./src/scripts/rss.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@react-navigation/native": "^7.0.0",
    "dayjs": "^1.11.9",
    "expo": "^55.0.13",
    "expo-constants": "~55.0.13",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.11",
    "expo-status-bar": "~55.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "react-use": "^17.4.2",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/gtag.js": "^0.0.18",
    "@types/react": "~19.2.10",
    "ajv": "^8.12.0",
    "bun-types": "latest",
    "chalk": "^5.6.2",
    "esbuild": "^0.19.2",
    "esbuild-register": "^3.4.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "prettier": "^3.0.3",
    "react-native-svg-transformer": "^1.1.0",
    "rss-parser": "^3.13.0",
    "ts-node": "^10.9.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun lint"
  },
  "overrides": {
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=22"
  }
}
