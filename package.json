{
  "name": "h.s",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint --fix ./src/**/*.tsx",
    "format": "prettier --write ./src/**/*.tsx",
    "publish:web": "bun rss && expo export -p web",
    "preview:web": "bunx serve dist",
    "rss": "bunx ts-node ./src/scripts/rss.ts",
    "rss:node": "node -r esbuild-register ./src/scripts/rss.ts"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@react-navigation/native": "^7.0.0",
    "dayjs": "^1.11.9",
    "expo": "~54.0.0",
    "expo-constants": "~17.0.0",
    "expo-font": "~13.3.0",
    "expo-image": "~2.3.0",
    "expo-linking": "~7.1.0",
    "expo-router": "~6.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.25.0",
    "react-native-reanimated": "~4.0.0",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.0",
    "react-native-svg": "~15.11.0",
    "react-native-web": "~0.20.0",
    "react-native-worklets": "~0.7.0",
    "react-use": "^17.4.2",
    "typescript": "~5.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.0.0",
    "@types/gtag.js": "^0.0.18",
    "@typescript-eslint/eslint-plugin": "^6.6.0",
    "@typescript-eslint/parser": "^6.6.0",
    "ajv": "^8.12.0",
    "bun-types": "latest",
    "esbuild": "^0.19.2",
    "esbuild-register": "^3.4.2",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.0.3",
    "react-native-svg-transformer": "^1.1.0",
    "rss-parser": "^3.13.0",
    "ts-node": "^10.9.1"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
